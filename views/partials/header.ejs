<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus Help Desk | Enterprise Support</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS for styling -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-bg: #f8fbf9;
            --card-bg: rgba(255, 255, 255, 0.95);
            --brand-color: #10b981; /* Emerald Green */
            --brand-gradient: linear-gradient(135deg, #10b981 0%, #0d9488 100%); /* Emerald to Teal */
            --text-main: #1e293b;
        }
        body { 
            font-family: 'Outfit', sans-serif;
            background: var(--primary-bg);
            background-image: 
                radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.08) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(13, 148, 136, 0.08) 0px, transparent 50%),
                radial-gradient(at 50% 100%, rgba(132, 204, 22, 0.08) 0px, transparent 50%);
            background-attachment: fixed;
            color: var(--text-main);
            padding-top: 1.5rem; 
            padding-bottom: 3rem;
            min-height: 100vh;
        }
        .navbar { 
            margin-bottom: 2.5rem; 
            border-radius: 16px;
            background: var(--brand-gradient) !important;
            box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 1rem 1.5rem;
        }
        .navbar-brand {
            font-size: 1.4rem;
            letter-spacing: -0.5px;
        }
        .nav-link {
            font-weight: 500;
            padding: 0.5rem 1rem !important;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.1);
            transform: translateY(-1px);
        }
        .admin-link {
            background: rgba(255, 255, 255, 0.15) !important;
            color: #fff !important;
            border: 1px solid rgba(255,255,255,0.2);
            text-shadow: 0 1px 2px rgba(0,0,0,0.1);
        }
        .admin-link:hover {
            background: #fff !important;
            color: var(--brand-color) !important;
            box-shadow: 0 4px 12px rgba(255,255,255,0.2);
        }
        
        /* Premium Card Styles */
        .premium-card {
            background: var(--card-bg);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.05);
            backdrop-filter: blur(20px);
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s;
        }
        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 60px -15px rgba(16, 185, 129, 0.15);
        }
        
        /* Inputs */
        .form-control, .form-select {
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            padding: 0.8rem 1.2rem;
            transition: all 0.3s;
            background: rgba(255,255,255,0.8);
            font-size: 1rem;
        }
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
            border-color: var(--brand-color);
            background: #fff;
        }
        .form-label {
            font-weight: 600;
            color: #334155;
            margin-bottom: 0.5rem;
        }
        
        /* Buttons */
        .btn-brand {
            background: var(--brand-gradient);
            color: white;
            border: none;
            border-radius: 12px;
            padding: 0.8rem 1.5rem;
            font-weight: 600;
            letter-spacing: 0.3px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-brand:hover {
            color: white;
            box-shadow: 0 10px 20px -5px rgba(16, 185, 129, 0.4);
            transform: translateY(-2px);
        }
        
        /* Custom Table */
        .custom-table {
            border-collapse: separate;
            border-spacing: 0 12px !important;
            background: transparent !important;
            width: 100%;
        }
        .table-responsive {
            background: transparent;
            box-shadow: none !important;
        }
        .custom-table thead th {
            border: none;
            background: transparent;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 1px;
            padding: 0 1.5rem 0.5rem;
        }
        .custom-table tbody tr {
            background: white !important;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            border-radius: 16px;
            transition: all 0.2s;
        }
        .custom-table tbody tr:hover {
            transform: scale(1.01);
            box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.1);
        }
        .custom-table tbody td {
            border: none !important;
            padding: 1.2rem 1.5rem !important;
            vertical-align: middle;
            background: transparent !important;
        }
        .custom-table tbody td:first-child { border-radius: 16px 0 0 16px; }
        .custom-table tbody td:last-child { border-radius: 0 16px 16px 0; }
        
        /* Badges */
        .badge {
            padding: 0.6em 1.2em;
            border-radius: 8px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .bg-danger-soft { background: #fee2e2 !important; color: #ef4444 !important; border: 1px solid #fecaca; }
        .bg-warning-soft { background: #fef3c7 !important; color: #d97706 !important; border: 1px solid #fde68a; }
        .bg-success-soft { background: #dcfce3 !important; color: #10b981 !important; border: 1px solid #bbf7d0; }
        .bg-primary-soft { background: #dcfce3 !important; color: #10b981 !important; border: 1px solid #bbf7d0; } /* Reusing success color base for green theme primary */
        .bg-secondary-soft { background: #f1f5f9 !important; color: #64748b !important; border: 1px solid #e2e8f0; }
        .bg-info-soft { background: #cffafe !important; color: #0891b2 !important; border: 1px solid #a5f3fc; }
        
        .text-primary { color: var(--brand-color) !important; }
        .bg-primary { background-color: var(--brand-color) !important; }
        .btn-primary { background-color: var(--brand-color) !important; border-color: var(--brand-color) !important; }
        .btn-primary:hover { background-color: #059669 !important; border-color: #059669 !important; }
        
        /* Text gradients */
        .text-gradient {
            background: var(--brand-gradient);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Dark Mode Settings */
        [data-bs-theme="dark"] {
            --primary-bg: #0f172a;
            --card-bg: rgba(30, 41, 59, 0.95);
            --text-main: #f8fafc;
        }
        [data-bs-theme="dark"] body {
            background-image: 
                radial-gradient(at 0% 0%, rgba(16, 185, 129, 0.15) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(13, 148, 136, 0.15) 0px, transparent 50%),
                radial-gradient(at 50% 100%, rgba(132, 204, 22, 0.15) 0px, transparent 50%);
        }
        [data-bs-theme="dark"] .bg-white { background-color: #1e293b !important; color: #f8fafc !important; border-color: rgba(255,255,255,0.1) !important; }
        [data-bs-theme="dark"] .text-dark { color: #f8fafc !important; }
        [data-bs-theme="dark"] .text-muted { color: #94a3b8 !important; }
        [data-bs-theme="dark"] .bg-light { background-color: #1e293b !important; border-color: rgba(255,255,255,0.05) !important; }
        [data-bs-theme="dark"] .form-control, [data-bs-theme="dark"] .form-select { background: rgba(15, 23, 42, 0.8); border-color: #334155; color: #f8fafc; }
        [data-bs-theme="dark"] .form-control:focus, [data-bs-theme="dark"] .form-select:focus { background: rgba(15, 23, 42, 1); }
        [data-bs-theme="dark"] .custom-table tbody tr { background: rgba(30, 41, 59, 0.9) !important; }
        [data-bs-theme="dark"] .custom-table thead th { color: #cbd5e1; }
        [data-bs-theme="dark"] .form-label { color: #cbd5e1; }
        [data-bs-theme="dark"] .premium-card { border-color: rgba(255, 255, 255, 0.1); }

        /* Animations */
        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fade-in {
            animation: fadeInDown 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</head>
<body>
    <div class="container animate-fade-in">
        <!-- Navigation Bar -->
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" href="/">
                    <i class="bi bi-layers-fill me-2 fs-4 align-middle"></i>
                    Nexus Support Desk
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto ps-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-white d-flex align-items-center" href="/">
                                <i class="bi bi-plus-square-dotted me-2"></i> Submit Issue
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="nav-link text-white d-flex align-items-center" href="/tickets">
                                <i class="bi bi-inboxes me-2"></i> All Tickets
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link admin-link fw-bold px-4 rounded-pill" href="/admin">
                                <i class="bi bi-shield-check me-2"></i> Admin Portal
                            </a>
                        </li>
                        <li class="nav-item ms-3">
                            <button id="themeToggleBtn" class="btn btn-outline-light rounded-circle shadow-sm d-flex align-items-center justify-content-center border-0" style="width: 44px; height: 44px; background: rgba(255,255,255,0.15); transition: all 0.3s;" onclick="toggleTheme()" title="Toggle Dark/Light Mode">
                                <i class="bi bi-moon-stars-fill fs-5" id="themeIcon"></i>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        
        <!-- Theme Script -->
        <script>
            function initTheme() {
                const isDark = localStorage.getItem('theme') === 'dark';
                document.documentElement.setAttribute('data-bs-theme', isDark ? 'dark' : 'light');
                updateThemeIcon(isDark);
            }
            function toggleTheme() {
                const currentTheme = document.documentElement.getAttribute('data-bs-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateThemeIcon(newTheme === 'dark');
            }
            function updateThemeIcon(isDark) {
                const icon = document.getElementById('themeIcon');
                const btn = document.getElementById('themeToggleBtn');
                if (isDark) {
                    icon.className = 'bi bi-sun-fill text-warning fs-5';
                    btn.style.transform = 'rotate(180deg)';
                } else {
                    icon.className = 'bi bi-moon-stars-fill fs-5';
                    btn.style.transform = 'rotate(0deg)';
                }
            }
            initTheme(); // Initialize on load
        </script>
        
        <!-- Main Content Area Starts -->
